# ═══════════════════════════════════════════════════
#  StoneVision AI — Frontend Environment Variables
#  Copy this file to .env.local and fill in values
#  NEVER commit .env.local to GitHub
# ═══════════════════════════════════════════════════

# Supabase (same values as backend — anon key only, NOT service key)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY

# Your Railway backend URL (get after Railway deploy)
NEXT_PUBLIC_API_URL=https://YOUR_APP.up.railway.app

# Your Vercel frontend URL (get after Vercel deploy)
NEXT_PUBLIC_APP_URL=https://YOUR_APP.vercel.app
